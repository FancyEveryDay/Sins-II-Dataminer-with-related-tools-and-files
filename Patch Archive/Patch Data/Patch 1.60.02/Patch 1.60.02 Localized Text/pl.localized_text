  "dlc2_advent_rebel_super_capital_ship_loot_name": "Wrak justicii",
  "dlc2_advent_rebel_super_capital_ship_malefic_locus_unit_item_description": "Złowrogi wzmacniacz PsiTech, który zwiększa potencjał zadawania obrażeń zdolnościami Justicia.",
  "dlc2_advent_rebel_super_capital_ship_malefic_locus_unit_item_name": "Złowrogi węzeł",
  "dlc2_advent_rebel_super_capital_ship_mind_locus_unit_item_description": "Tajemniczy wzmacniacz PsiTech, który zwiększa potencjał wsparcia zdolności używanych przez Justicję.",
  "dlc2_advent_rebel_super_capital_ship_mind_locus_unit_item_name": "Centrum umysłu",
  "dlc2_advent_rebel_super_capital_ship_name": "Drednot justicia",
  "dlc2_advent_rebel_super_capital_ship_savior_locus_unit_item_description": "Niezłomny wzmacniacz PsiTech, który zwiększa obronny potencjał zdolności używanych przez Justicję.",
  "dlc2_advent_rebel_super_capital_ship_savior_locus_unit_item_name": "Ognisko zbawienia",
  "dlc2_advent_rebel_super_flare_ability_description": "Justicia ładuje się, by uwolnić zgromadzoną energię w niszczycielnej fali. Podczas ładowania zadaje lekkie obrażenia pobliskim wrogom, po czym zużywa całą antymaterię w jednej katastrofalnej eksplozji.\\n\\nTo zdolność kanałowana — można ją zakończyć wcześniej, wydając temu statkowi polecenie Stop.",
  "dlc2_advent_rebel_super_flare_ability_name": "Flara",
  "dlc2_advent_rebel_super_flare_antimatter_consumed": "Justicia - zużyta antymateria:",
  "dlc2_advent_rebel_super_flare_damage_per_antimatter": "Obrażenia za jednostkę antymaterii Justicii:",
  "dlc2_advent_rebel_super_harvest_ability_description": "Energia zniszczonych sojuszniczych okrętów jest zbierana przez Justicia i przechowywana — na krótko zwiększa to jej maksymalny zapas antymaterii. Podczas zbierania zniszczony okręt wyemituje wybuch energii, którego efekt zależy od tego, jaki locus jest założony.",
  "dlc2_advent_rebel_super_harvest_ability_name": "Zbiór",
