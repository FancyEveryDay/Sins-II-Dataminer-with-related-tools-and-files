  "missions.build_new_exotics.name": "Gromadź egzotyki",
  "missions.build_new_ships.name": "Rozbuduj flotę",
  "missions.build_ships": "Buduj statki:",
  "missions.build_ships_tooltip_desc": "Rozbudowa floty o więcej okrętów bojowych to zawsze priorytet. Nawet małe, słabsze statki mogą przechylić szalę bitwy na twoją korzyść, jeśli jest ich wystarczająco dużo. Jeśli masz nadmiar zasobów i nie wiesz, co z nimi zrobić, budowa kolejnych okrętów bojowych to zawsze dobry wybór.",
  "missions.build_ships_tooltip_title": "Budowa statków",
  "missions.build_starbase_name": "Zbuduj stację kosmiczną:",
  "missions.build_structures_desc": "Struktury mogą mieć różne zastosowania. Niektóre budują statki do twojej floty, inne służą jako statyczna obrona, a jeszcze inne poprawiają twoją ekonomię, bezpośrednio lub pośrednio.",
  "missions.build_structures_title": "Budowanie struktur",
  "missions.build_titan_name": "Buduj tytanów:",
  "missions.build_unit_item_name": "Zbuduj {} {}:",
  "missions.build_units_of_type": "Zbuduj {}:",
  "missions.build_units_of_type_tooltip_title": "Role statków",
  "missions.build_units_of_types_tooltip_desc": "W Sins 2 różne statki mają różne role. Niektóre świetnie atakują z daleka, ale kiepsko znoszą bliskie starcia. Inne są super w wsparciu, ale słabe w zadawaniu obrażeń. Eksperymentuj z różnymi składami floty, by znaleźć ten, który najlepiej pasuje do twojego stylu gry!",
  "missions.build_vasari_factory": "Zbuduj fabrykę montażu nano:",
