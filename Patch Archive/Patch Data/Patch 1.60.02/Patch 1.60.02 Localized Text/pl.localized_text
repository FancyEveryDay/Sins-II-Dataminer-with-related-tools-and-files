  "planet_bonus.ancient_arcology.name": "Starożytna arkologia",
  "planet_bonus.ancient_mine_factory.desc": "Odkryto dawno opuszczoną fabrykę zawierającą charakterystyczne elementy architektury zarówno traderów, jak i Adventu, choć wyraźnie nie należy do żadnej z tych frakcji. Czas budowy statków w fabrykach jest skrócony.",
  "planet_bonus.ancient_mine_factory.name": "Starożytna fabryka",
  "planet_bonus.antimatter_cores.desc": "Wysokoenergetyczne cząstki nasycają studnię grawit. tej planety, przez co wszystkie bronie zadają zwiększone obrażenia.",
  "planet_bonus.antimatter_cores.name": "Przestrzeń energetyczna",
  "planet_bonus.antimatter_fountain.desc": "Naturalna antymateria może być zbierana przez pobliskie statki, aby uzupełnić ich zapasy.",
  "planet_bonus.antimatter_fountain.name": "Fontanna antymaterii",
  "planet_bonus.automated_factories.desc": "Odkrywcy trafiają na zautomatyzowany kompleks fabryczny sterowany przez zaawansowaną SI. Koszty budowy struktur i statków są obniżone.",
  "planet_bonus.automated_factories.name": "Zautomatyzowane fabryki",
  "planet_bonus.bombardment_shelters.desc": "Odkrywcy odnajdują system schronów ukrytych głęboko pod powierzchnią planety. Na ścianach widnieje wiele dziwnych symboli, które handlarze uznają za instynktownie obraźliwe. Uszkodzenia od bombardowania są znacznie mniejsze.",
  "planet_bonus.bombardment_shelters.name": "Schrony przeciwbombowe",
  "planet_bonus.brown_dwarf.desc": "Intensywne światło podczerwone od brązowego karła obrysowuje pobliskie statki i pomaga w namierzaniu celów, znacznie zwiększając zasięg broni i zdolności statków na orbicie.",
  "planet_bonus.brown_dwarf.name": "Sylwetki w podczerwieni",
  "planet_bonus.cavern_system.desc": "Odkryto sieć złożonych jaskiń głęboko pod powierzchnią, zapewniającą bezpieczniejsze schronienie dla populacji podczas ataku. Zwiększa zdrowie planety.",
  "planet_bonus.cavern_system.name": "Nadający się do zamieszkania system jaskiń",
  "planet_bonus.chaotic_weather.desc": "Pogoda na planecie jest nieprzewidywalna i ekstremalna; dochody maleją, koszty budowy rosną.",
  "planet_bonus.chaotic_weather.name": "Chaotyczna pogoda",
  "planet_bonus.death_world.desc": "Atmosfera tego świata zawiera dziwne, sztuczne cząsteczki biologiczne, zagrażające zarówno powierzchni, jak i bliskiej orbicie. Infrastruktura populacji i cywilne stacje orbitalne są ograniczone, a koszty budowy rosną.",
  "planet_bonus.death_world.name": "Świat śmierci",
  "planet_bonus.dense_atmosphere.desc": "Atmosfera świata jest bardzo gęsta, co utrudnia bombardowanie planetarne.",
  "planet_bonus.dense_atmosphere.name": "Gęsta atmosfera",
  "planet_bonus.dense_core.desc": "Gęste, żelazne jądro w centrum tej planety znacznie rozszerza jej studnię grawit.",
  "planet_bonus.dense_core.name": "Gęste jądro",
  "planet_bonus.dust_storms.desc": "Intensywne burze pyłowe przetaczają się przez planetę, utrudniając rozwój i zmniejszając dochody z kredytów.",
  "planet_bonus.dust_storms.name": "Stałe burze pyłowe",
  "planet_bonus.feudal_society.desc": "Planetą rządzi arystokracja, co utrudnia osiąganie zysków, ale sprawia, że praca jest tania, choć powolna.",
  "planet_bonus.feudal_society.name": "Społeczeństwo feudalne",
  "planet_bonus.fortress_world.desc": "Na tej od dawna opuszczonej planecie znaleziono pozostałości miast zgodnych z wczesnymi wzorcami dynastii Aluxi. Bastiony odbudowano, zmieniając świat w fortecę. Wzmocniono obronę i dodano infrastrukturę wojskową.",
  "planet_bonus.fortress_world.name": "Świat-twierdza",
  "planet_bonus.free_market_society.desc": "Megakorporacje rządzą planetą, otwierając ludność na nowe kultury, handel i tanią siłę roboczą.",
  "planet_bonus.free_market_society.name": "Społeczeństwo wolnorynkowe",
  "planet_bonus.fusion_power_core.desc": "Odkryto reaktor fuzyjny, co pozwala na wsparcie większej liczby obiektów orbitalnych.",
  "planet_bonus.fusion_power_core.name": "Fuzjowy rdzeń zasilania",
  "planet_bonus.geothermal_heat_source.desc": "Wiele punktów o ograniczonej aktywności wulkanicznej na planecie zapewnia łatwy dostęp do energii, umożliwiając większy rozwój cywilny.",
  "planet_bonus.geothermal_heat_source.name": "Gorące punkty geotermalne",
  "planet_bonus.hazardous_space.desc": "Załogi statków zdobywają doświadczenie szybciej, walcząc w egzotycznych i niebezpiecznych środowiskach.",
  "planet_bonus.hazardous_space.name": "Niebezpieczna przestrzeń",
  "planet_bonus.healing_nanites.desc": "Odkryto placówkę medyczną Vasari, co poprawia wzrost populacji i pojemność.",
  "planet_bonus.healing_nanites.name": "Leczące nanoboty",
  "planet_bonus.helium_atmosphere.desc": "Obfite zasoby helu w atmosferze ułatwiają jego pozyskiwanie, co zwiększa dochody z eksportu tego chłodziwa.",
  "planet_bonus.helium_atmosphere.name": "Atmosfera bogata w hel.",
  "planet_bonus.high_gravity.desc": "Niezwykle wysoki poziom metali ciężkich sprawia, że jądro tej planety jest niezwykle gęste, co skutkuje dużą studnią grawit. w stosunku do jej objętości.",
  "planet_bonus.high_gravity.name": "Gęste płynne jądro",
  "planet_bonus.huge_glaciers.desc": "Daje bonus do dochodu dzięki dostępowi do czystej wody.",
  "planet_bonus.huge_glaciers.name": "Ogromne czyste lodowce",
  "planet_bonus.ice_field.desc": "To pole lodu dryfowało z obłoku Oorta w tym systemie, stwarzając niewielkie zagrożenie dla nawigacji. Walczące jednostki muszą zachować ostrożność, ponieważ liczne fragmenty lodu odbijają obrażenia zadane bronią.",
  "planet_bonus.ice_field.name": "Odbijające cząsteczki lodowe",
  "planet_bonus.impassable_well.desc": "Z powodu dziwnego zniekształcenia czasoprzestrzeni nie można opuścić tej studni grawitacyjnej, gdy się w niej znajdzie.",
  "planet_bonus.impassable_well.name": "Nieprzekraczalna studnia grawit.",
  "planet_bonus.industrial_wasteland.desc": "Rozległe zakłady produkcyjne pokrywają powierzchnię, zwiększając wydobycie zasobów.",
  "planet_bonus.industrial_wasteland.name": "Przemysłowe pustkowie",
  "planet_bonus.intense_gravity_field.desc": "Planeta ma wyższe pole grawitacyjne niż wskazuje jej rozmiar, więc statki muszą lecieć dalej, by wykonać skok fazowy.",
  "planet_bonus.intense_gravity_field.name": "Intensywne pole grawitacyjne",
  "planet_bonus.ionic_storms.desc": "Silnie jonizowana atmosfera wywołuje częste burze, zmniejszając maksymalną populację, ale dostarczając energię do przejęcia.",
  "planet_bonus.ionic_storms.name": "Burze jonowe",
  "planet_bonus.low_gravity.desc": "Jądro tej planety ostygło i stało się porowate, co skutkuje niezwykle małą studnią grawit. w stosunku do jej objętości.",
  "planet_bonus.low_gravity.name": "Porowate jądro",
  "planet_bonus.magnetic_cloud.desc": "Chaotyczne pola magnetyczne zakłócają użycie aktywnych zdolności i ciąg głównych silników.",
  "planet_bonus.magnetic_cloud.name": "Zakłócenia magnetyczne",
  "planet_bonus.medicinal_plants.desc": "Bogata bioróżnorodność planety ułatwia rozwój leków, co sprawia, że ludzie są zdrowsi i bardziej produktywni.",
  "planet_bonus.medicinal_plants.name": "Farmaceutyczna flora",
  "planet_bonus.mega_fauna.desc": "Ogromne zwierzęta stadne migrują wzdłuż pierścienia równikowego, dostarczając cennych futer i żywności.",
  "planet_bonus.mega_fauna.name": "Megafauna",
  "planet_bonus.meteorite_craters.desc": "Ciągłe uderzenia meteorytów czynią kolonie na powierzchni niepraktycznymi, ale stanowią źródło cennych surowców.",
  "planet_bonus.meteorite_craters.name": "Częste meteoryty",
  "planet_bonus.neutron_magnetic_flux.desc": "Potwornie silne, szybko wirujące pola magnetyczne gwiazdy neutronowej zdzierają tarcze i zakłócają używanie zdolności statków na orbicie.",
  "planet_bonus.neutron_magnetic_flux.name": "Neutronowy strumień magnetyczny",
  "planet_bonus.oceanic_energy_converter.desc": "Podwodne badania odkrywają system konwersji fal oceanicznych na energię, co zwiększa handel.",
  "planet_bonus.oceanic_energy_converter.name": "Konwerter energii oceanicznej",
  "planet_bonus.pirate_treasure.desc": "Ogromny skarbiec nieuczciwie zdobytych bogactw trafia do twojej stolicy, ładownia po ładowni. Zapewnia premię do dochodu z kredytów.",
  "planet_bonus.pirate_treasure.name": "Zrabowane łupy",
  "planet_bonus.plasma_storm.desc": "Niebezpieczne chmury plazmy uniemożliwiają start myśliwców szturmowych i odpalenie rakiet, a także wymuszają blokadę doków konstrukcyjnych, wstrzymując budowę nowych okrętów.",
  "planet_bonus.plasma_storm.name": "Burza plazmowa",
  "planet_bonus.polluted_environment.desc": "Skanowanie powierzchni ujawnia, że planeta jest mocno zanieczyszczona przez to, co mogła być dawna broń wojenna. Rozwój tej planety będzie trudny.",
  "planet_bonus.polluted_environment.name": "Zanieczyszczone środowisko",
  "planet_bonus.quantum_comm_hub.desc": "Odkryto kwantowy system łączności, co przyspiesza badania prowadzone na tym świecie.",
  "planet_bonus.quantum_comm_hub.name": "Centrum komunikacji kwantowej",
  "planet_bonus.radiation_storm.desc": "Gwałtowne skupiska promieniowania uniemożliwiają użycie pasywnych systemów naprawy i regeneracji.",
  "planet_bonus.radiation_storm.name": "Burza radiacyjna",
  "planet_bonus.rusted_core.desc": "Jądro tego świata prawie całkowicie zgniło, zmniejszając jego studnię grawitacyjną i ograniczając ilość metalu pozostałego do wydobycia.",
  "planet_bonus.rusted_core.name": "Zardzewiały rdzeń",
  "planet_bonus.shattered_planet.desc": "Gorąca, energetyczna materia planetarna wypełniająca tę przestrzeń zakłóca sensory, znacznie zmniejszając zasięg broni, zasięg umiejętności i śledzenie celów przez wieżyczki.",
  "planet_bonus.shattered_planet.name": "Pozostałości planety",
  "planet_bonus.ship_factories.desc": "Odkryto kilometry prowizorycznie zbudowanych portów kosmicznych nieznanego pochodzenia. Ich odbudowa znacznie zwiększa możliwości budowy nowych statków w tym miejscu.",
  "planet_bonus.ship_factories.name": "Wydajne fabryki statków",
  "planet_bonus.singularity_gravity_slingshot.desc": "Kolosalne przyciąganie grawitacyjne czarnej dziury jest wykorzystywane przez statki znajdujące się w jej polu grawitacyjnym, aby zwiększyć ich prędkość ruchu.",
  "planet_bonus.singularity_gravity_slingshot.name": "Grawitacyjna proca osobliwości",
  "planet_bonus.singularity_time_dilation.desc": "Czasoprzestrzeń jest zakrzywiona w pobliżu czarnej dziury, co powoduje znaczną dylatację czasu dla pobliskich statków.",
  "planet_bonus.singularity_time_dilation.name": "Dylatacja czasu osobliwości",
  "planet_bonus.solar_energy_reserves.desc": "Cienka atmosfera i bliskość słońca umożliwiają tej planecie łatwy dostęp do energii słonecznej, co pozwala jej wspierać więcej struktur orbitalnych.",
  "planet_bonus.solar_energy_reserves.name": "Pozyskiwanie energii słonecznej",
  "planet_bonus.solar_gravity_slingshot.desc": "Statki znajdujące się w polu grawitacyjnym gwiazdy wykorzystują jej ogromne przyciąganie grawitacyjne, aby zwiększyć swoją prędkość ruchu.",
  "planet_bonus.solar_gravity_slingshot.name": "Słoneczna proca grawitacyjna",
  "planet_bonus.solar_regeneration.desc": "Intensywne promieniowanie gwiazdowe znacznie zwiększa tempo regeneracji antymaterii.",
  "planet_bonus.solar_regeneration.name": "Regeneracja słoneczna",
  "planet_bonus.space_pony.desc": "Uchodźcy z cukrowej góry.",
  "planet_bonus.space_pony.name": "Kosmiczne kucyki!",
  "planet_bonus.spice_trade.desc": "Wysoko poszukiwany surowiec, który zwiększa świadomość konsumenta – cenny towar eksportowy.",
  "planet_bonus.spice_trade.name": "Handel przyprawami",
  "planet_bonus.stable_debris_field.desc": "Względnie statyczne pole szczątków ułatwia odzysk cennych metali i ruch statków handlowych przez obszar, co zwiększa dochody.",
  "planet_bonus.stable_debris_field.name": "Stabilne pole szczątków",
  "planet_bonus.subsurface_crystal_deposits.desc": "W tym systemie znaleziono duże ilości kryształu, zwiększając ilość surowca, którą górnicy kryształu mogą wydobyć.",
  "planet_bonus.subsurface_crystal_deposits.name": "Podpowierzchniowe złoża kryształów",
  "planet_bonus.subsurface_metal_deposits.desc": "W tym systemie odkryto duże ilości cennych rud, co zwiększyło ilość metali, którą górnicy są w stanie wydobyć.",
  "planet_bonus.subsurface_metal_deposits.name": "Podpowierzchniowe złoża metali",
  "planet_bonus.subzero_twisters.desc": "Atmosfera tej planety generuje śmiertelne tornada z lodu i śniegu. Przestrzeń dla populacji jest ograniczona, a koszty budowy znacznie wyższe.",
  "planet_bonus.subzero_twisters.name": "Lodowe tornada",
  "planet_bonus.surplus_foodstuffs.desc": "Duże ilości urodzajnej ziemi i lokalna wiedza dają obfite plony.",
  "planet_bonus.surplus_foodstuffs.name": "Eksperckie społeczeństwo agrarne",
  "planet_bonus.thermal_lift.desc": "Rozległe prądy termiczne ułatwiają transport surowców na orbitę, co ułatwia budowę struktur wokół tej planety.",
  "planet_bonus.thermal_lift.name": "Naturalny termiczny prąd wznoszący",
  "planet_bonus.toxic_fallout.desc": "Długotrwała wojna chemiczna między regionalnymi frakcjami na tej planecie spowodowała utrzymywanie się toksyn w atmosferze, przez co rozwój planety jest powolny i kosztowny.",
  "planet_bonus.toxic_fallout.name": "Toksyczny opad",
  "planet_bonus.trader_mining.desc": "Odnaleziono opuszczoną kopalnię metalu Trade Order, zwiększając dochody z metalu.",
  "planet_bonus.trader_mining.name": "Opuszczona kopalnia",
  "planet_bonus.tropical_paradise.desc": "Unikalne nachylenie osiowe tego świata czyni go tropikalnym ogrodem.",
  "planet_bonus.tropical_paradise.name": "Tropikalny raj",
  "planet_bonus.undersea_caverns.desc": "Oceany tej planety skrywają ogromne jaskinie, które dają miejsce na dodatkowe przedmioty planetarne.",
  "planet_bonus.undersea_caverns.name": "Podwodne jaskinie",
  "planet_bonus.undersea_weapons.desc": "Głęboko pod powierzchnią oceanu spoczywają zniszczone przez czas pozostałości starożytnej wojskowej technologii.",
  "planet_bonus.undersea_weapons.name": "Broń podwodna",
  "planet_bonus.virulent_plague.desc": "Orbitalne latarnie ostrzegają, że planeta jest zagrożona śmiertelną plagą. Ekspedycje odkrywają masowe groby starożytnych ludzkich szczątków; wiele ciał nosi ślady rozległej sztucznej rekonstrukcji lub manipulacji.",
