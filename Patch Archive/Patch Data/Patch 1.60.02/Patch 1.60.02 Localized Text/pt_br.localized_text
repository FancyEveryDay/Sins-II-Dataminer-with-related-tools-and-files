  "dlc2_trader_loyalist_super_capital_ship_factory_supplies_unit_item_description": "Reabastece os pods de carga do Takadaran com suprimentos para construção de naves.",
  "dlc2_trader_loyalist_super_capital_ship_factory_supplies_unit_item_name": "Carga: materiais da fábrica",
