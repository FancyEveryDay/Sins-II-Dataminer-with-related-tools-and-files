  "tutorial_camera_controls.begin": "Bem-vindo ao Controle Básico de Câmera, Comandante. Estamos felizes que você escolheu fazer nosso curso rápido para visualizar seu novo império.",
  "tutorial_camera_controls.description": "Veja seu império aprendendo a controlar a câmera.",
  "tutorial_camera_controls.end": "Parabéns! Você concluiu o tutorial de Câmera Básica.",
  "tutorial_camera_controls.name": "Controles da câmera",
  "tutorial_camera_controls.pan_with_keyboard": "Com o zoom dominado, vamos passar para o movimento da câmera usando o teclado. Tente mover para a esquerda agora.",
  "tutorial_camera_controls.pan_with_keyboard_01": "E agora, mova a câmera para a direita...",
