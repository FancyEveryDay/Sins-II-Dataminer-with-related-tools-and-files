{
    "version": 0,
    "stacking_limit":
    {
        "stacking_limit": "fixed_one",
        "stacking_limit_met_behavior": "preserve_existing_buff"
    },
    "make_dead_on_source_ability_released": true,
    "stacking_ownership_type": "for_all_players",
    "restart_other_stacked_buffs_when_started": true,
    "trigger_event_actions": [
    {
        "trigger_event_type": "on_parent_buff_made_dead",
        "action_group":
        {
            "actions": [
            {
                "action_type": "use_unit_operators_on_single_unit",
                "destination_unit":
                {
                    "unit_type": "current_spawner"
                },
                "operators": [
                {
                    "operator_type": "apply_buff",
                    "buff": "dlc2_vasari_rebel_super_capital_ship_phase_gate_timer"
                }]
            }]
        }
    },
    {
        "trigger_event_type": "on_child_buff_made_dead",
        "action_group":
        {
            "constraint":
            {
                "constraint_type": "buff_made_dead_has_context",
                "buff_made_dead_context": "duration_expired"
            },
            "actions": [
            {
                "action_type": "make_buff_dead",
                "buff": "current_buff"
            }]
        }
    }],
    "provides_temporary_phase_stabilizer": true
}
